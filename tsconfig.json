{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "*.ts",
    "src/**/*.ts",
    "testing/**/*.ts",
    "testModules/**/*.ts",
    "tools/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".git",
    ".backups"
  ]
}
